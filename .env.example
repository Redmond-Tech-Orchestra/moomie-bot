# Copy to .env and fill in the values below.
#
# Only secrets live here. Non-secret config (Discord IDs, GitHub repo names,
# port, etc.) has sensible defaults in src/config.ts and only needs to be
# overridden if you want a different value for local dev.

# ---------------------------------------------------------------------------
# Discord — bot token
# ---------------------------------------------------------------------------
# Where to get it: https://discord.com/developers/applications
#   → Redmond Tech Orchestra Bot (Moomie) → Bot → Reset Token
DISCORD_TOKEN=

# ---------------------------------------------------------------------------
# GitHub App — used to open PRs, comment on issues, etc.
# ---------------------------------------------------------------------------
# Where to get the private key:
#   https://github.com/organizations/Redmond-Tech-Orchestra/settings/apps/moomie-bot
#   → Private keys → Generate a private key (downloads a .pem)
# Drop the .pem next to docker-compose.yml; in production it lives at
# /opt/moomie-bot/moomie-bot.<date>.private-key.pem and is mounted into the
# container.
GITHUB_APP_PRIVATE_KEY_PATH=

# ---------------------------------------------------------------------------
# GitHub webhook — shared secret for verifying incoming webhooks
# ---------------------------------------------------------------------------
# Set the same value in each repo's webhook settings:
#   https://github.com/Redmond-Tech-Orchestra/<repo>/settings/hooks
# Pick anything random; rotate by updating both sides.
GITHUB_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Gemini — LLM API key for chat, extraction, dedup
# ---------------------------------------------------------------------------
# Where to get it: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Teams (optional — only set if running the Teams adapter)
# ---------------------------------------------------------------------------
# Where to get them: https://portal.azure.com → App registrations → moomie-bot
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# ---------------------------------------------------------------------------
# Eventbrite — private token for archive + live sales tools
# ---------------------------------------------------------------------------
# Where to get it: https://www.eventbrite.com/account-settings/apps
#   → "Show" under Your private token. Inherits your user's permissions on
#   the Redmond Tech Orchestra organization (no scope granularity).
# Only the moomie-bot main process reads this. It is NEVER passed into any
# sandboxed subprocess.
EVENTBRITE_PRIVATE_TOKEN=

# ---------------------------------------------------------------------------
# Overrides (optional — defaults live in src/config.ts)
# ---------------------------------------------------------------------------
# Uncomment + set only if you need to deviate from the defaults. Examples:
# DISCORD_CLIENT_ID=
# DISCORD_GUILD_ID=
# PERFORMANCES_CATEGORY_ID=
# ARCHIVED_CATEGORY_ID=
# GITHUB_OWNER=
# GITHUB_REPO=
# GITHUB_APP_ID=
# GITHUB_APP_INSTALLATION_ID=
# BOT_OWNER_ID=
# MUSIC_ADMIN_ROLE=
# CODING_AGENT=
# AGENT_WORKSPACE=
# PORT=
# EVENTBRITE_ORG_ID=
# EVENTBRITE_DATA_DIR=
