# Copy to .env and fill in the values below.
#
# Only secrets live here. Non-secret config (Discord IDs, GitHub repo names,
# port, etc.) has sensible defaults in src/config.ts and only needs to be
# overridden if you want a different value for local dev.

# ---------------------------------------------------------------------------
# Discord — bot token
# ---------------------------------------------------------------------------
# Where to get it: https://discord.com/developers/applications
#   → Redmond Tech Orchestra Bot (Moomie) → Bot → Reset Token
DISCORD_TOKEN=

# ---------------------------------------------------------------------------
# GitHub App — used to open PRs, comment on issues, etc.
# ---------------------------------------------------------------------------
# Where to get the private key:
#   https://github.com/organizations/Redmond-Tech-Orchestra/settings/apps/moomie-bot
#   → Private keys → Generate a private key (downloads a .pem)
# Drop the .pem next to docker-compose.yml; in production it lives at
# /opt/moomie-bot/moomie-bot.<date>.private-key.pem and is mounted into the
# container.
GITHUB_APP_PRIVATE_KEY_PATH=

# ---------------------------------------------------------------------------
# GitHub webhook — shared secret for verifying incoming webhooks
# ---------------------------------------------------------------------------
# Set the same value in each repo's webhook settings:
#   https://github.com/Redmond-Tech-Orchestra/<repo>/settings/hooks
# Pick anything random; rotate by updating both sides.
GITHUB_WEBHOOK_SECRET=

# Deploy endpoint auth (optional). If set, POST /deploy requires a matching
# `x-deploy-token` header. If unset, the endpoint only accepts loopback calls
# (the on-server deploy script). Set this if /deploy is reachable off-box.
DEPLOY_TOKEN=

# ---------------------------------------------------------------------------
# LLM provider — chat, extraction, dedup, analytics
# ---------------------------------------------------------------------------
# The bot talks to LLMs through the Vercel AI SDK. The provider is chosen by
# LLM_PROVIDER (defaults to "openai" in src/config.ts); supply that provider's
# API key here. Each provider authenticates with a plain key — no OAuth/login.
#
#   openai → https://platform.openai.com/api-keys
#   gemini → https://aistudio.google.com/apikey   (only if LLM_PROVIDER=gemini)
OPENAI_API_KEY=
GEMINI_API_KEY=

# OpenAI-compatible gateway override (optional). Leave unset to hit
# api.openai.com. To test the OpenAI path for free against GitHub Models:
#   OPENAI_BASE_URL=https://models.github.ai/inference
#   OPENAI_API_KEY=<a GitHub PAT with models:read>  (or a `gh auth token`)
#   OPENAI_MODEL_*=openai/gpt-4o-mini  (GitHub Models IDs are namespaced)
OPENAI_BASE_URL=

# ---------------------------------------------------------------------------
# Teams (optional — only set if running the Teams adapter)
# ---------------------------------------------------------------------------
# Where to get them: https://portal.azure.com → App registrations → moomie-bot
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# ---------------------------------------------------------------------------
# Eventbrite — private token for archive + live sales tools
# ---------------------------------------------------------------------------
# Where to get it: https://www.eventbrite.com/account-settings/apps
#   → "Show" under Your private token. Inherits your user's permissions on
#   the Redmond Tech Orchestra organization (no scope granularity).
# Only the moomie-bot main process reads this. It is NEVER passed into any
# sandboxed subprocess.
EVENTBRITE_PRIVATE_TOKEN=

# ---------------------------------------------------------------------------
# Coding agent — runtime knobs (the agent itself is picked by CODING_AGENT,
# which defaults to "codex" in src/config.ts)
# ---------------------------------------------------------------------------
# Codex reuses OPENAI_API_KEY for auth; set CODEX_API_KEY only to use a
# different key for the coding agent than for the chat/LLM calls.
# CODEX_API_KEY=
# CODEX_MODEL=           # pin a codex model; unset = codex's built-in default
# CODEX_SANDBOX=         # read-only | workspace-write | danger-full-access
#                        # Production Docker sets danger-full-access because the
#                        # hardened container is the boundary; workspace-write
#                        # needs unprivileged namespaces/landlock that may be
#                        # unavailable inside Docker.
# GEMINI_MODEL=          # pin a model when CODING_AGENT=gemini

# ---------------------------------------------------------------------------
# Other overrides
# ---------------------------------------------------------------------------
# DB_PATH=               # SQLite path (default: ./data/moomie.db)
#
# Everything else (Discord/GitHub IDs, repo names, PORT, role names, model
# selection: LLM_PROVIDER / MODEL_* / OPENAI_MODEL_*, CODING_AGENT,
# AGENT_WORKSPACE, EVENTBRITE_ORG_ID, …) has a sensible default in
# src/config.ts. Set the matching env var there only to deviate from it.
