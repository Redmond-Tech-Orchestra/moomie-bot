{
  "name": "moomie-bot",
  "version": "1.0.0",
  "description": "Discord bot that creates GitHub issues and assigns Copilot",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx --watch src/index.ts",
    "lint": "eslint src/",
    "deploy-commands": "tsx src/deploy-commands.ts",
    "deploy": "powershell -ExecutionPolicy Bypass -File deploy.ps1"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^21.0.0",
    "better-sqlite3": "^11.0.0",
    "botbuilder": "^4.23.0",
    "chrono-node": "^2.7.0",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^10.3.0",
    "smee-client": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.1"
  }
}
